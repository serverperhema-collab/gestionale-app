{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/commerciale",
      "destination": "/commerciale.html"
    },
    {
      "source": "/api/:path*",
      "destination": "https://gestionale-backend-mfph.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
